# ============================================================
# AI-OA Docker Environment Configuration
# Copy this file to .env and customize values
# All values here can be overridden in docker-compose
# ============================================================

# ── Project ─────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=aioa

# ── Backend Source Path ─────────────────────────────────────
# Path to backend source root (contains pom.xml and all modules)
BACKEND_SOURCE=../../source/backend

# Path to frontend dist directory
FRONTEND_DIST_PATH=../../source/frontend/dist

# Dockerfile path (default: ./Dockerfile.app in the docker dir)
DOCKERFILE_PATH=./Dockerfile.app

# ── Spring Profile ──────────────────────────────────────────
SPRING_PROFILES=dev

# ── Database (MySQL) ────────────────────────────────────────
DB_PASSWORD=root123456
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ai_oa

MYSQL_PORT=3306

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

REDIS_PORT=6379

# ── JWT ─────────────────────────────────────────────────────
# Must be at least 256 bits (32 characters) for HS256
JWT_SECRET=aioa-jwt-secret-key-for-signing-tokens-must-be-at-least-256-bits-long

# ── Ports ───────────────────────────────────────────────────
# Backend services (mapped to host)
GATEWAY_PORT=8080
SYSTEM_PORT=8081
WORKFLOW_PORT=8082
KNOWLEDGE_PORT=8083
AI_PORT=8084
ASSET_PORT=8085
ATTENDANCE_PORT=8086
HR_PORT=8087
LICENSE_PORT=8088
OCR_PORT=8089
REIMBURSE_PORT=8090
REPORT_PORT=8091
IM_PORT=8092

# Frontend
FRONTEND_HTTP_PORT=80
FRONTEND_HTTPS_PORT=443

# Nginx API Gateway
NGINX_PORT=8000

# ── AI Provider API Keys ───────────────────────────────────
# MiniMax (Mimo) - currently enabled in aioa-ai
MIMI_API_KEY=tp-cl8gb60kvi9ieqdkwk7gfopb579cem3jw75dum8sfom2egu8

# OpenAI (disabled by default)
OPENAI_API_KEY=

# Anthropic Claude (disabled by default)
CLAUDE_API_KEY=

# ── Java JVM Options ────────────────────────────────────────
JAVA_XMS=256m
JAVA_XMX=1024m
