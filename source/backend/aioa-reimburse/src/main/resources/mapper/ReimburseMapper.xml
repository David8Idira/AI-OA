<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aioa.reimburse.mapper.ReimburseMapper">

    <resultMap id="BaseResultMap" type="com.aioa.reimburse.entity.Reimburse">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="type" property="type"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="currency" property="currency"/>
        <result column="status" property="status"/>
        <result column="priority" property="priority"/>
        <result column="applicant_id" property="applicantId"/>
        <result column="applicant_name" property="applicantName"/>
        <result column="dept_id" property="deptId"/>
        <result column="dept_name" property="deptName"/>
        <result column="approver_id" property="approverId"/>
        <result column="approver_name" property="approverName"/>
        <result column="cc_users" property="ccUsers"/>
        <result column="reimburse_date" property="reimburseDate"/>
        <result column="expect_pay_date" property="expectPayDate"/>
        <result column="pay_date" property="payDate"/>
        <result column="pay_method" property="payMethod"/>
        <result column="bank_account" property="bankAccount"/>
        <result column="bank_name" property="bankName"/>
        <result column="attachments" property="attachments"/>
        <result column="description" property="description"/>
        <result column="approval_comment" property="approvalComment"/>
        <result column="reject_reason" property="rejectReason"/>
        <result column="cancel_reason" property="cancelReason"/>
        <result column="ocr_auto_fill" property="ocrAutoFill"/>
        <result column="invoice_count" property="invoiceCount"/>
        <result column="receipt_attached" property="receiptAttached"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectByApplicantId" resultMap="BaseResultMap">
        SELECT * FROM reimburse
        WHERE deleted = 0 AND applicant_id = #{applicantId}
        ORDER BY create_time DESC
    </select>

    <select id="selectPendingByApproverId" resultMap="BaseResultMap">
        SELECT * FROM reimburse
        WHERE deleted = 0 AND approver_id = #{approverId} AND status = 1
        ORDER BY create_time DESC
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM reimburse
        WHERE deleted = 0 AND status = #{status}
        ORDER BY create_time DESC
    </select>

    <select id="searchByKeyword" resultMap="BaseResultMap">
        SELECT * FROM reimburse
        WHERE deleted = 0
        <if test="keyword != null and keyword != ''">
            AND (title LIKE CONCAT('%', #{keyword}, '%') OR description LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="applicantId != null and applicantId != ''">
            AND applicant_id = #{applicantId}
        </if>
        <if test="approverId != null and approverId != ''">
            AND approver_id = #{approverId}
        </if>
        <if test="type != null and type != ''">
            AND type = #{type}
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

    <select id="countByApplicantId" resultType="long">
        SELECT COUNT(*) FROM reimburse WHERE deleted = 0 AND applicant_id = #{applicantId}
    </select>

    <select id="countPendingByApproverId" resultType="long">
        SELECT COUNT(*) FROM reimburse
        WHERE deleted = 0 AND approver_id = #{approverId} AND status = 1
    </select>

    <select id="selectOverdue" resultMap="BaseResultMap">
        SELECT * FROM reimburse
        WHERE deleted = 0
        AND status = 1
        AND expect_pay_date IS NOT NULL
        AND expect_pay_date &lt; NOW()
        ORDER BY expect_pay_date ASC
    </select>

    <select id="selectByIds" resultMap="BaseResultMap">
        SELECT * FROM reimburse
        WHERE deleted = 0 AND id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY create_time DESC
    </select>

</mapper>
