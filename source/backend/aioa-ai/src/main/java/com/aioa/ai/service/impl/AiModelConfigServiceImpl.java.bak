package com.aioa.ai.service.impl;

import com.aioa.ai.entity.AiModelConfig;
import com.aioa.ai.mapper.AiModelConfigMapper;
import com.aioa.ai.service.AiModelConfigService;
import com.aioa.common.exception.BusinessException;
import com.aioa.common.result.ResultCode;
import com.baomidou.mybatisplus.core.conditions.query.LambdaQueryWrapper;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;

/**
 * AI Model Configuration Service Implementation
 */
@Slf4j
@Service
public class AiModelConfigServiceImpl implements AiModelConfigService {
    
    @Autowired
    private AiModelConfigMapper aiModelConfigMapper;
    
    @Override
    public List<AiModelConfig> getAllEnabled() {
        log.debug("Getting all enabled AI models");
        List<AiModelConfig> models = aiModelConfigMapper.selectAllEnabled();
        log.info("Found {} enabled AI models", models.size());
        return models;
    }
    
    @Override
    public AiModelConfig getConfigByCode(String modelCode) {
        log.debug("Getting AI model config for code: {}", modelCode);
        if (modelCode == null || modelCode.trim().isEmpty()) {
            throw new BusinessException(ResultCode.BAD_REQUEST, "Model code cannot be empty");
        }
        
        LambdaQueryWrapper<AiModelConfig> queryWrapper = new LambdaQueryWrapper<>();
        queryWrapper.eq(AiModelConfig::getModelCode, modelCode);
        AiModelConfig config = aiModelConfigMapper.selectOne(queryWrapper);
        
        if (config == null) {
            log.warn("AI model config not found for code: {}", modelCode);
            throw new BusinessException(ResultCode.NOT_FOUND, "AI model config not found: " + modelCode);
        }
        
        if (config.getEnabled() == null || config.getEnabled() == 0) {
            log.warn("AI model is disabled: {}", modelCode);
            throw new BusinessException(ResultCode.SERVICE_UNAVAILABLE, "AI model is disabled: " + modelCode);
        }
        
        return config;
    }
    
    @Override
    public AiModelConfig getDefaultConfig(String functionType) {
        log.debug("Getting default AI model config for function: {}", functionType);
        if (functionType == null || functionType.trim().isEmpty()) {
            throw new BusinessException(ResultCode.BAD_REQUEST, "Function type cannot be empty");
        }
        
        AiModelConfig config = aiModelConfigMapper.selectDefaultConfig(functionType);
        
        if (config == null) {
            log.warn("No default AI model config found for function: {}", functionType);
            // Fallback to first enabled model
            List<AiModelConfig> enabledModels = getAllEnabled();
            if (!enabledModels.isEmpty()) {
                config = enabledModels.get(0);
                log.info("Using fallback model: {} for function: {}", config.getModelCode(), functionType);
            } else {
                throw new BusinessException(ResultCode.SERVICE_UNAVAILABLE, "No enabled AI models available");
            }
        }
        
        return config;
    }
    
    @Override
    @Transactional(rollbackFor = Exception.class)
    public void incrementUsage(String modelCode) {
        log.debug("Incrementing usage count for model: {}", modelCode);
        
        // First check if model exists and is enabled
        AiModelConfig config = getConfigByCode(modelCode);
        
        // Check daily limit
        if (config.getDailyLimit() != null && config.getDailyLimit() > 0) {
            if (config.getTodayUsage() != null && config.getTodayUsage() >= config.getDailyLimit()) {
                log.error("Daily limit reached for model: {}, limit: {}, usage: {}", 
                    modelCode, config.getDailyLimit(), config.getTodayUsage());
                throw new BusinessException(ResultCode.AI_MODEL_QUOTA_EXCEEDED, 
                    String.format("Daily limit reached for model %s: %d/%d", 
                        modelCode, config.getTodayUsage(), config.getDailyLimit()));
            }
        }
        
        // Increment usage
        int updated = aiModelConfigMapper.incrementUsage(modelCode);
        if (updated <= 0) {
            log.error("Failed to increment usage for model: {}", modelCode);
            throw new BusinessException(ResultCode.INTERNAL_SERVER_ERROR, "Failed to update usage count");
        }
        
        log.debug("Successfully incremented usage for model: {}", modelCode);
    }
    
    @Override
    @Transactional(rollbackFor = Exception.class)
    public void saveConfig(AiModelConfig config) {
        log.debug("Saving AI model config: {}", config.getModelCode());
        
        if (config == null || config.getModelCode() == null) {
            throw new BusinessException(ResultCode.BAD_REQUEST, "Invalid AI model config");
        }
        
        // Check if model already exists
        LambdaQueryWrapper<AiModelConfig> queryWrapper = new LambdaQueryWrapper<>();
        queryWrapper.eq(AiModelConfig::getModelCode, config.getModelCode());
        boolean exists = aiModelConfigMapper.exists(queryWrapper);
        
        if (exists) {
            // Update existing config
            queryWrapper = new LambdaQueryWrapper<>();
            queryWrapper.eq(AiModelConfig::getModelCode, config.getModelCode());
            int updated = aiModelConfigMapper.update(config, queryWrapper);
            
            if (updated <= 0) {
                log.error("Failed to update AI model config: {}", config.getModelCode());
                throw new BusinessException(ResultCode.INTERNAL_SERVER_ERROR, "Failed to update AI model config");
            }
            
            log.info("Updated AI model config: {}", config.getModelCode());
        } else {
            // Insert new config
            int inserted = aiModelConfigMapper.insert(config);
            
            if (inserted <= 0) {
                log.error("Failed to insert AI model config: {}", config.getModelCode());
                throw new BusinessException(ResultCode.INTERNAL_SERVER_ERROR, "Failed to insert AI model config");
            }
            
            log.info("Inserted new AI model config: {}", config.getModelCode());
        }
    }
    
    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean toggleModelEnabled(String modelCode) {
        log.info("Toggling AI model {} to enabled: {}", modelCode, enabled);
        
        // Check if model exists
        LambdaQueryWrapper<AiModelConfig> queryWrapper = new LambdaQueryWrapper<>();
        queryWrapper.eq(AiModelConfig::getModelCode, modelCode);
        AiModelConfig existing = aiModelConfigMapper.selectOne(queryWrapper);
        
        if (existing == null) {
            throw new BusinessException(ResultCode.NOT_FOUND, "AI model not found: " + modelCode);
        }
        
        // Update enabled status
        AiModelConfig updateConfig = new AiModelConfig();
        updateConfig.setId(existing.getId());
        updateConfig.setEnabled(enabled ? 1 : 0);
        
        int updated = aiModelConfigMapper.updateById(updateConfig);
        if (updated <= 0) {
            log.error("Failed to toggle AI model: {}", modelCode);
            throw new BusinessException(ResultCode.INTERNAL_SERVER_ERROR, "Failed to toggle AI model");
        }
        
        log.info("Successfully toggled AI model {} to enabled: {}", modelCode, enabled);
    }
}