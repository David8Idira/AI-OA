<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aioa.report.mapper.ReportMapper">

    <resultMap id="BaseResultMap" type="com.aioa.report.entity.Report">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="type" property="type"/>
        <result column="status" property="status"/>
        <result column="content" property="content"/>
        <result column="template_id" property="templateId"/>
        <result column="template_name" property="templateName"/>
        <result column="data_source" property="dataSource"/>
        <result column="period_start" property="periodStart"/>
        <result column="period_end" property="periodEnd"/>
        <result column="creator_id" property="creatorId"/>
        <result column="creator_name" property="creatorName"/>
        <result column="dept_id" property="deptId"/>
        <result column="dept_name" property="deptName"/>
        <result column="ai_model" property="aiModel"/>
        <result column="chart_config" property="chartConfig"/>
        <result column="export_path" property="exportPath"/>
        <result column="export_format" property="exportFormat"/>
        <result column="summary" property="summary"/>
        <result column="tags" property="tags"/>
        <result column="view_count" property="viewCount"/>
        <result column="is_pinned" property="isPinned"/>
        <result column="share_scope" property="shareScope"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectReportPage" resultMap="BaseResultMap">
        SELECT * FROM report
        WHERE deleted = 0
        <if test="keyword != null and keyword != ''">
            AND (title LIKE CONCAT('%', #{keyword}, '%')
                 OR content LIKE CONCAT('%', #{keyword}, '%')
                 OR tags LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="type != null and type != ''">
            AND type = #{type}
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        <if test="creatorId != null and creatorId != ''">
            AND creator_id = #{creatorId}
        </if>
        <if test="deptId != null and deptId != ''">
            AND dept_id = #{deptId}
        </if>
        <if test="startDate != null and startDate != ''">
            AND create_time &gt;= #{startDate}
        </if>
        <if test="endDate != null and endDate != ''">
            AND create_time &lt;= #{endDate}
        </if>
        ORDER BY
        <choose>
            <when test="sortField == 'title'">title</when>
            <when test="sortField == 'status'">status</when>
            <when test="sortField == 'type'">type</when>
            <when test="sortField == 'viewCount'">view_count</when>
            <when test="sortField == 'updateTime'">update_time</when>
            <otherwise>create_time</otherwise>
        </choose>
        <choose>
            <when test="sortOrder == 'asc'">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
    </select>

</mapper>
